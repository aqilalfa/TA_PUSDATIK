{
  "permissions": {
    "allow": [
      "Bash(curl -s http://localhost*)",
      "Bash(curl -v http://localhost*)",
      "Bash(curl -s -X POST \"http://localhost*)",
      "Bash(curl -s -X POST http://localhost*)",
      "Bash(pdftotext *)",
