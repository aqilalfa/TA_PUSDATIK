# =============================================================================
# SPBE RAG System - Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment

# =============================================================================
# QDRANT CONFIGURATION
# =============================================================================
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=spbe_documents

# =============================================================================
# LLM MODEL CONFIGURATION
# =============================================================================
# Path to model GGUF (relative to /app/models in container)
MODEL_PATH=/app/models/llm/qwen-2.5-7b-instruct-q4_k_m.gguf

# GPU configuration for GTX 1650 (4GB VRAM)
MODEL_N_GPU_LAYERS=35          # Number of layers on GPU (tune based on VRAM)
MODEL_N_CTX=8192               # Context window
MODEL_N_BATCH=512              # Batch size
MODEL_TEMP=0.1                 # Temperature for generation
MODEL_TOP_P=0.95
MODEL_TOP_K=40
MODEL_MAX_TOKENS=2048

# =============================================================================
# EMBEDDING MODEL CONFIGURATION
# =============================================================================
EMBEDDING_MODEL=firqaaa/indo-sentence-bert-base
EMBEDDING_CACHE_DIR=/app/models/embeddings
EMBEDDING_DEVICE=cpu           # cpu or cuda
EMBEDDING_BATCH_SIZE=32

# =============================================================================
# RERANKER MODEL CONFIGURATION
# =============================================================================
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_CACHE_DIR=/app/models/reranker
RERANKER_DEVICE=cpu
RERANKER_TOP_K=10

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=sqlite:////app/database/spbe_rag.db

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# =============================================================================
# RAG CONFIGURATION
# =============================================================================
# Hybrid Search
VECTOR_SEARCH_TOP_K=20
BM25_TOP_K=20
HYBRID_ALPHA=0.6               # Weight for vector search (0.6 = 60% vector, 40% BM25)

# Retrieval
RETRIEVAL_TOP_K=10             # Final top-k after reranking
CHUNK_SIZE=512                 # Tokens per chunk
CHUNK_OVERLAP=50               # Overlap between chunks

# =============================================================================
# OCR CONFIGURATION
# =============================================================================
OCR_ENGINE=paddleocr           # paddleocr or tesseract
OCR_LANG=id                    # Language for OCR
OCR_USE_GPU=true               # Use GPU for OCR

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================
SESSION_MAX_HISTORY=10         # Max conversation turns to keep in memory
SESSION_TIMEOUT=3600           # Session timeout in seconds (1 hour)

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR
LOG_DIR=/app/logs
LOG_FORMAT=json                # json or text

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=development        # development or production
DEBUG=true
RELOAD=true                    # Enable auto-reload for development

# =============================================================================
# CUDA/GPU
# =============================================================================
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# FRONTEND
# =============================================================================
VITE_API_URL=http://localhost:8000
NODE_ENV=development
