# =============================================================================
# SPBE RAG System - Docker Environment Configuration
# =============================================================================
# Copy this file to .env.docker and use with:
#   docker-compose -f docker-compose.dev.yml --env-file .env.docker up
# =============================================================================

# =============================================================================
# QDRANT CONFIGURATION
# =============================================================================
# Use Docker service name, NOT localhost
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=document_chunks

# =============================================================================
# LLM / OLLAMA
# =============================================================================
# Ollama runs on the host machine — use host.docker.internal to reach it from inside Docker
OLLAMA_BASE_URL=http://host.docker.internal:11434

# =============================================================================
# EMBEDDING & RERANKER
# =============================================================================
EMBEDDING_MODEL=firqaaa/indo-sentence-bert-base
EMBEDDING_CACHE_DIR=/app/models/embeddings
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_CACHE_DIR=/app/models/reranker
RERANKER_DEVICE=cpu
RERANKER_TOP_K=10

# =============================================================================
# DATABASE
# =============================================================================
# Correct container path (backend/data/ is mounted to /app/data/)
DATABASE_URL=sqlite:////app/data/spbe_rag.db

# =============================================================================
# API
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# =============================================================================
# RAG
# =============================================================================
VECTOR_SEARCH_TOP_K=20
BM25_TOP_K=20
HYBRID_ALPHA=0.6
RETRIEVAL_TOP_K=10
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# =============================================================================
# OCR
# =============================================================================
OCR_ENGINE=paddleocr
OCR_LANG=id
OCR_USE_GPU=true

# =============================================================================
# SESSION
# =============================================================================
SESSION_MAX_HISTORY=10
SESSION_TIMEOUT=3600

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=/app/logs
LOG_FORMAT=json

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENVIRONMENT=production
DEBUG=false
RELOAD=false

# =============================================================================
# GPU
# =============================================================================
CUDA_VISIBLE_DEVICES=0

# =============================================================================
# FRONTEND
# =============================================================================
# VITE_API_URL: browser accesses backend via exposed port on the host
VITE_API_URL=http://localhost:8000
# VITE_BACKEND_PROXY: Vite dev server inside container proxies /api to backend service
VITE_BACKEND_PROXY=http://backend:8000
NODE_ENV=production
